            --// ── tabAPI:AddSlider ──────────────────────────
            function tabAPI:AddSlider(label, callback, settings)
                local sliderAPI = {}
                label    = tostring(label or "New Slider")
                callback = typeof(callback)  == "function" and callback  or function() end
                settings = typeof(settings)  == "table"    and settings  or {}
                settings.min      = settings.min      or 0
                settings.max      = settings.max      or 100
                settings.readonly = settings.readonly or false

                local sl     = Prefabs:FindFirstChild("Slider"):Clone()
                local target = contentFrame:FindFirstChild("TabScroller") or contentFrame
                sl.Parent    = target
                sl.ZIndex    = sl.ZIndex + windowCount * 10

                local slTitle = sl:FindFirstChild("Title")
                local slFill  = sl:FindFirstChild("Indicator")
                local slValue = sl:FindFirstChild("Value")
                slTitle.ZIndex = slTitle.ZIndex + windowCount * 10
                slFill.ZIndex  = slFill.ZIndex  + windowCount * 10
                slValue.ZIndex = slValue.ZIndex + windowCount * 10
                slTitle.Text   = label

                local mouseOverSlider = false
                local sliderConn

                sl.MouseEnter:Connect(function() mouseOverSlider = true;  win.Draggable = false end)
                sl.MouseLeave:Connect(function() mouseOverSlider = false; win.Draggable = true  end)

                local mouseDown = false

                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        mouseDown = true
                        if mouseOverSlider and not settings.readonly then
                            sliderConn = RunService.Heartbeat:Connect(function()
                                if not mouseDown or dropdownOpen then
                                    if sliderConn then sliderConn:Disconnect(); sliderConn = nil end
                                    return
                                end
                                local pos  = getMousePos()
                                local pct  = math.clamp((pos.X - sl.AbsolutePosition.X) / sl.AbsoluteSize.X, 0, 1)
                                slFill.Size = UDim2.new(pct, 0, 0, 20)
                                local raw  = math.floor(pct * 100)
                                local val  = math.floor((settings.max - settings.min) / 100 * raw + settings.min)
                                slValue.Text = tostring(val)
                                pcall(callback, val)
                            end)
                        end
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        mouseDown = false
                        if sliderConn then sliderConn:Disconnect(); sliderConn = nil end
                    end
                end)

                function sliderAPI:Set(value)
                    value = math.clamp(tonumber(value) or 0, 0, 100) / 100
                    slFill.Size = UDim2.new(value, 0, 0, 20)
                    local raw = math.floor(value * 100)
                    local val = math.floor((settings.max - settings.min) / 100 * raw + settings.min)
                    slValue.Text = tostring(val)
                    pcall(callback, val)
                end

                sliderAPI:Set(settings.min)
                return sliderAPI, sl
            end

            --// ── tabAPI:AddKeybind ─────────────────────────
