        -- Minimize button: toggle tabs visibility
        local tabs = win:FindFirstChild("Tabs")
        barToggle.MouseButton1Click:Connect(function()
            local tabsVisible = tabs.Visible
            if tabsVisible then
                tabs.Visible = false
                tween(win, { Size = UDim2.new(0, win.AbsoluteSize.X, 0, barHeight) }, options.tween_time)
            else
                tabs.Visible = true
                win.Size = UDim2.new(0, win.AbsoluteSize.X, 0, options.min_size.Y)
            end
        end)
