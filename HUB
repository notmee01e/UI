                local keybindAPI = {}
                label    = tostring(label or "New Keybind")
                callback = typeof(callback) == "function" and callback or function() end
                settings = typeof(settings) == "table"    and settings or {}
                settings.standard = settings.standard or Enum.KeyCode.RightShift

                local kb     = Prefabs:FindFirstChild("Keybind"):Clone()
