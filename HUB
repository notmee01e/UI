    --// ── Resize handle (bottom-right corner drag) ─────────
    local resizer    = win:WaitForChild("Resizer")
    local windowAPI  = {}

    win.Draggable = true

    do
        local savedIcon = Mouse.Icon
        local mouseOver = false

        resizer.MouseEnter:Connect(function()
            win.Draggable = false
            if options.can_resize then savedIcon = Mouse.Icon end
            mouseOver = true
        end)

        resizer.MouseLeave:Connect(function()
            mouseOver = false
            if options.can_resize then Mouse.Icon = savedIcon end
            win.Draggable = true
        end)

        local mouseDown     = false
        local resizeConn

        UserInputService.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                mouseDown = true
                if mouseOver and resizer.Active and options.can_resize then
                    resizeConn = RunService.Heartbeat:Connect(function()
                        if not mouseDown or not resizer.Active then
                            if resizeConn then resizeConn:Disconnect(); resizeConn = nil end
                            return
                        end
                        local pos  = getMousePos()
                        local newW = math.max(options.min_size.X, pos.X - win.AbsolutePosition.X)
                        local newH = math.max(options.min_size.Y, pos.Y - win.AbsolutePosition.Y)
                        win.Size   = UDim2.new(0, newW, 0, newH)
                    end)
                end
            end
        end)

        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                mouseDown = false
                if resizeConn then resizeConn:Disconnect(); resizeConn = nil end
            end
        end)
    end

    --// ── Collapse animation (title bar toggle button) ─────
    do
        local collapseBtn   = win:FindFirstChild("Bar"):FindFirstChild("Toggle")
        local isExpanded    = true
        local canAnimate    = true
        local savedTabState = {}
        local savedHeight   = win.AbsoluteSize.Y

        collapseBtn.MouseButton1Click:Connect(function()
            if not canAnimate then return end
            canAnimate = false

            if isExpanded then
                -- Collapse: hide all tabs, shrink window
                savedTabState = {}
                for _, child in ipairs(win:FindFirstChild("Tabs"):GetChildren()) do
                    savedTabState[child] = child.Visible
                    child.Visible = false
                end
                resizer.Active = false
                savedHeight    = win.AbsoluteSize.Y
                tween(collapseBtn, { Rotation = 0 }, options.tween_time)
                tween(win, { Size = UDim2.new(0, win.AbsoluteSize.X, 0, 26) }, options.tween_time)

                local base = collapseBtn.Parent:FindFirstChild("Base")
                if base then base.Transparency = 1 end
            else
                -- Expand: restore tabs
                for child, wasVisible in pairs(savedTabState) do
                    child.Visible = wasVisible
                end
                resizer.Active = true
                tween(collapseBtn, { Rotation = 0 }, options.tween_time)
                tween(win, { Size = UDim2.new(0, win.AbsoluteSize.X, 0, savedHeight) }, options.tween_time)

                local base = collapseBtn.Parent:FindFirstChild("Base")
                if base then base.Transparency = options.title_bar_transparency end
            end

