                kbTitle.ZIndex = kbTitle.ZIndex + windowCount * 10

                local target = contentFrame:FindFirstChild("TabScroller") or contentFrame
                kb.Parent    = target
                kbTitle.Text = "  " .. label
                kb.Size      = UDim2.new(0, getTextWidth(kbTitle) + 80, 0, 20)

                -- Short display names for common keys
                local keyAliases = {
                    RightControl = "RightCtrl",
                    LeftControl  = "LeftCtrl",
                    LeftShift    = "LShift",
                    RightShift   = "RShift",
                    MouseButton1 = "Mouse1",
                    MouseButton2 = "Mouse2",
                }

                local currentKey = settings.standard

                function keybindAPI:SetKeybind(keyCode)
                    kbInput.Text = keyAliases[keyCode.Name] or keyCode.Name
                    currentKey   = keyCode
                end

                -- Fire callback when the assigned key is pressed
                UserInputService.InputBegan:Connect(function(input, processed)
                    if bindingActive then
                        task.defer(function() bindingActive = false end)
                        return
                    end
                    if input.KeyCode == currentKey and not processed then
                        pcall(callback, currentKey)
                    end
                end)

                keybindAPI:SetKeybind(settings.standard)

                -- Click to rebind
                kbInput.MouseButton1Click:Connect(function()
                    if bindingActive then return end
                    kbInput.Text  = "..."
                    bindingActive = true
                    local newInput = UserInputService.InputBegan:Wait()
                    keybindAPI:SetKeybind(newInput.KeyCode)
                end)

                return keybindAPI, kb
            end

            --// ── tabAPI:AddDropdown ────────────────────────
            function tabAPI:AddDropdown(label, callback)
                local dropdownAPI = {}
                label    = tostring(label or "New Dropdown")
                callback = typeof(callback) == "function" and callback or function() end

                local dd      = Prefabs:FindFirstChild("Dropdown"):Clone()
                local ddBox   = dd:FindFirstChild("Box")
                local ddList  = ddBox:FindFirstChild("Objects")
                local ddArrow = dd:FindFirstChild("Indicator")

                dd.ZIndex    = dd.ZIndex    + windowCount * 10
                ddBox.ZIndex = ddBox.ZIndex + windowCount * 10
                ddList.ZIndex = ddList.ZIndex + windowCount * 10
                ddArrow.ZIndex = ddArrow.ZIndex + windowCount * 10
                dd.Size      = UDim2.new(0.5, -5, 0, 20)

                local ddBg = dd:GetChildren()[3]
                ddBg.ZIndex             = ddBg.ZIndex + windowCount * 10
                ddBg.ImageTransparency  = options.title_bar_transparency or 0
                applyColor(ddBg, options.title_bar, 0)

                ddBox.ImageTransparency = options.background_transparency or 0.1
                applyColor(ddBox, options.background, 0)

                local ddCorner        = Instance.new("UICorner")
                ddCorner.CornerRadius = UDim.new(0, 6)
                ddCorner.Parent       = ddBox

                ddList.BackgroundTransparency = 1
                ddList.Position  = UDim2.new(0, 0, 0, 0)
                ddList.Size      = UDim2.new(1, 0, 1, 0)

                local target = contentFrame:FindFirstChild("TabScroller") or contentFrame
                dd.Parent    = target
                dd.Text      = "      " .. label
                ddBox.Size   = UDim2.new(1, 0, 0, 0)
                ddBox.Position = UDim2.new(0, 0, 0, 25)
                dd.TextColor3 = Color3.new(1, 1, 1)

                local isOpen    = false
                local opensUp   = false

                dd.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    local itemCount  = #ddList:GetChildren() - 1
                    local boxHeight  = math.min(itemCount * 20, 200)

                    if itemCount >= 10 then
                        ddList.CanvasSize = UDim2.new(0, 0, itemCount * 0.1, 0)
                    end

                    if isOpen then
                        if dropdownOpen then return end
                        dropdownOpen = true

                        -- Decide: open up or down depending on available space
                        local btnBottom  = dd.AbsolutePosition.Y + dd.AbsoluteSize.Y
                        local winBottom  = win.AbsolutePosition.Y + win.AbsoluteSize.Y
                        local spaceBelow = winBottom - btnBottom

                        if spaceBelow < boxHeight then
                            opensUp = true
                            ddBox.Position = UDim2.new(0, 0, 0, -boxHeight - 5)
                            ddBox.Size     = UDim2.new(1, 0, 0, 0)
                            tween(ddBox, { Size = UDim2.new(1, 0, 0, boxHeight), Position = UDim2.new(0, 0, 0, -boxHeight - 5) }, options.tween_time)
                        else
                            opensUp = false
                            ddBox.Position = UDim2.new(0, 0, 0, 25)
                            ddBox.Size     = UDim2.new(1, 0, 0, 0)
                            tween(ddBox, { Size = UDim2.new(1, 0, 0, boxHeight) }, options.tween_time)
                        end
                        tween(ddArrow, { Rotation = 90 }, options.tween_time)
                    else
                        dropdownOpen = false
                        if opensUp then
                            local t = TweenService:Create(ddBox, TweenInfo.new(options.tween_time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, -5) })
                            t:Play()
                            t.Completed:Connect(function() ddBox.Position = UDim2.new(0, 0, 0, 25) end)
                        else
                            tween(ddBox, { Size = UDim2.new(1, 0, 0, 0) }, options.tween_time)
                        end
                        tween(ddArrow, { Rotation = -90 }, options.tween_time)
                    end
                end)

                --// dropdownAPI:Add  – add an item
                function dropdownAPI:Add(itemName)
                    local itemAPI = {}
                    itemName = tostring(itemName or "New Object")

                    local item = Prefabs:FindFirstChild("DropdownButton"):Clone()
                    item.Parent               = ddList
                    item.Text                 = "      " .. itemName
                    item.ZIndex               = item.ZIndex + windowCount * 10 + 5
                    item.BackgroundTransparency = 1
                    item.TextColor3           = Color3.new(1, 1, 1)
                    item.BorderSizePixel      = 0
                    item.TextXAlignment       = Enum.TextXAlignment.Left

                    local oldCorner = item:FindFirstChildOfClass("UICorner")
                    if oldCorner then oldCorner:Destroy() end

                    local stroke           = Instance.new("UIStroke")
                    stroke.Color           = Color3.fromRGB(110, 30, 210)  -- purple
                    stroke.Thickness       = 1
                    stroke.Transparency    = 0.5
                    stroke.Parent          = item

                    item.MouseEnter:Connect(function()
                        item.BackgroundTransparency = 0.7
                        item.BackgroundColor3       = Color3.fromRGB(110, 30, 210)  -- purple hover
                    end)
                    item.MouseLeave:Connect(function()
                        item.BackgroundTransparency = 1
                    end)

                    -- Resize dropdown box if it's already open
                    if isOpen then
                        local itemCount = #ddList:GetChildren() - 1
                        local boxH      = math.min(itemCount * 20, 200)
                        if itemCount >= 10 then
                            ddList.CanvasSize = UDim2.new(0, 0, itemCount * 0.1, 0)
                        end
                        if opensUp then
                            tween(ddBox, { Size = UDim2.new(1, 0, 0, boxH), Position = UDim2.new(0, 0, 0, -boxH - 5) }, options.tween_time)
                        else
                            tween(ddBox, { Size = UDim2.new(1, 0, 0, boxH) }, options.tween_time)
                        end
                    end

                    item.MouseButton1Click:Connect(function()
                        if dropdownOpen then
                            dd.Text      = "      [ " .. itemName .. " ]"
                            dropdownOpen = false
                            isOpen       = false
                            if opensUp then
                                local t = TweenService:Create(ddBox, TweenInfo.new(options.tween_time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), { Size = UDim2.new(1, 0, 0, 0), Position = UDim2.new(0, 0, 0, -5) })
                                t:Play()
                                t.Completed:Connect(function() ddBox.Position = UDim2.new(0, 0, 0, 25) end)
                            else
                                tween(ddBox, { Size = UDim2.new(1, 0, 0, 0) }, options.tween_time)
                            end
                            tween(ddArrow, { Rotation = -90 }, options.tween_time)
                            pcall(callback, itemName)
                        end
                    end)

                    function itemAPI:Remove() item:Destroy() end
                    return item, itemAPI
                end

                --// dropdownAPI:Remove  – remove an item by name
                function dropdownAPI:Remove(itemName)
                    local found = ddList:FindFirstChild(itemName)
                    if found then
                        found:Destroy()
                        if dropdownAPI.currentSelection == itemName then
                            local first  = ddList:GetChildren()[1]
                            local newSel = first and first.Text or "No Selection"
                            dropdownAPI.currentSelection = newSel
                            dd.Text = "        [ " .. newSel .. " ]"
                            pcall(callback, newSel)
                        end
                    end
                end

                return dropdownAPI, dd
            end

            --// ── tabAPI:AddColorPicker ─────────────────────
            function tabAPI:AddColorPicker(callback)
                local pickerAPI = {}
                callback = typeof(callback) == "function" and callback or function() end

                local cp     = Prefabs:FindFirstChild("ColorPicker"):Clone()
                local target = contentFrame:FindFirstChild("TabScroller") or contentFrame
                cp.Parent    = target
                cp.ZIndex    = cp.ZIndex + windowCount * 10

                local palette   = cp:FindFirstChild("Palette")
                local sample    = cp:FindFirstChild("Sample")
                local satBar    = cp:FindFirstChild("Saturation")
                palette.ZIndex = palette.ZIndex + windowCount * 10
                sample.ZIndex  = sample.ZIndex  + windowCount * 10
                satBar.ZIndex  = satBar.ZIndex  + windowCount * 10

                local hue, sat, val = 0, 1, 1

                local function updateColor()
                    local color       = Color3.fromHSV(hue, sat, val)
                    sample.ImageColor3 = color
                    satBar.ImageColor3 = Color3.fromHSV(hue, 1, 1)
                    pcall(callback, color)
                end

                updateColor()

                local paletteHover, satHover = false, false

                palette.MouseEnter:Connect(function() win.Draggable = false; paletteHover = true  end)
                palette.MouseLeave:Connect(function() win.Draggable = true;  paletteHover = false end)
                satBar.MouseEnter:Connect(function()  win.Draggable = false; satHover = true      end)
                satBar.MouseLeave:Connect(function()  win.Draggable = true;  satHover = false     end)

                local paletteIndicator = palette:FindFirstChild("Indicator")
                local satIndicator     = satBar:FindFirstChild("Indicator")
                paletteIndicator.ZIndex = paletteIndicator.ZIndex + windowCount * 10
                satIndicator.ZIndex     = satIndicator.ZIndex     + windowCount * 10

                local mouseDown   = false
                local dragConn

                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        mouseDown = true
                        dragConn  = RunService.Heartbeat:Connect(function()
                            if not mouseDown or dropdownOpen then
                                if dragConn then dragConn:Disconnect(); dragConn = nil end
                                return
                            end
                            local pos = getMousePos()
                            if paletteHover then
                                local px = math.clamp((pos.X - palette.AbsolutePosition.X) / palette.AbsoluteSize.X, 0, 1)
                                local py = math.clamp((pos.Y - palette.AbsolutePosition.Y) / palette.AbsoluteSize.Y, 0, 1)
                                hue, sat = px, 1 - py
                                paletteIndicator.Position = UDim2.new(px, -paletteIndicator.AbsoluteSize.X / 2, py, -paletteIndicator.AbsoluteSize.Y / 2)
                                updateColor()
                            elseif satHover then
                                local py = math.clamp((pos.Y - satBar.AbsolutePosition.Y) / satBar.AbsoluteSize.Y, 0, 1)
                                val = 1 - py
                                satIndicator.Position = UDim2.new(0, 0, py, 0)
                                updateColor()
                            end
                        end)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        mouseDown = false
                        if dragConn then dragConn:Disconnect(); dragConn = nil end
                    end
                end)

                function pickerAPI:Set(color)
                    color = typeof(color) == "Color3" and color or Color3.new(1, 1, 1)
                    local h, s, v = rgbToHsv(color.r * 255, color.g * 255, color.b * 255)
                    sample.ImageColor3 = color
                    satBar.ImageColor3 = Color3.fromHSV(h, 1, 1)
                    pcall(callback, color)
                end

                return pickerAPI, cp
            end

            --// ── tabAPI:AddHorizontalAlignment ────────────
            function tabAPI:AddHorizontalAlignment()
                local hAlignAPI = {}
                local hAlign    = Prefabs:FindFirstChild("HorizontalAlignment"):Clone()
                local target    = contentFrame:FindFirstChild("TabScroller") or contentFrame
                hAlign.Parent   = target

                function hAlignAPI:AddButton(...)
                    local results = { tabAPI:AddButton(...) }
                    local btn     = results[#results]
                    btn.Parent    = hAlign
                    return table.unpack(results)
                end

                return hAlignAPI, hAlign
            end

            --// ── tabAPI:AddFolder ──────────────────────────
            function tabAPI:AddFolder(folderName)
                local folderAPI = {}
                folderName = tostring(folderName or "New Folder")

                local folder     = Prefabs:FindFirstChild("Folder"):Clone()
                local folderBtn  = folder:FindFirstChild("Button")
                local folderList = folder:FindFirstChild("Objects")
                local folderArr  = folderBtn:FindFirstChild("Toggle")

                folder.ZIndex    = folder.ZIndex    + windowCount * 10
                folderBtn.ZIndex = folderBtn.ZIndex + windowCount * 10
                folderList.ZIndex = folderList.ZIndex + windowCount * 10
                folderArr.ZIndex  = folderArr.ZIndex  + windowCount * 10
                folderBtn:GetChildren()[1].ZIndex = folderBtn:GetChildren()[1].ZIndex + windowCount * 10

                local target = contentFrame:FindFirstChild("TabScroller") or contentFrame
                folder.Parent = target
                folderBtn.Text = "      " .. folderName

                local folderBg = folderBtn:GetChildren()[1]
                folderBg.ImageColor3 = options.main_color

                -- Calculate total folder height based on children
                local function getFolderHeight()
                    local h = 25
                    for _, child in ipairs(folderList:GetChildren()) do
                        if not child:IsA("UIListLayout") then
                            h = h + child.AbsoluteSize.Y + 5
                        end
                    end
                    return h
                end

                local isOpen      = false
                local sizeConn

                folderBtn.MouseButton1Click:Connect(function()
                    isOpen = not isOpen
                    if isOpen then
                        tween(folderArr, { Rotation = 90 }, options.tween_time)
                        folderList.Visible = true
                        if sizeConn then sizeConn:Disconnect() end
                        sizeConn = RunService.Heartbeat:Connect(function()
                            if isOpen then
                                folder.Size = UDim2.new(1, 0, 0, getFolderHeight())
                            else
                                if sizeConn then sizeConn:Disconnect(); sizeConn = nil end
                            end
                        end)
                    else
                        tween(folderArr, { Rotation = 0 }, options.tween_time)
                        folderList.Visible = false
                        folder.Size = UDim2.new(1, 0, 0, 20)
                        if sizeConn then sizeConn:Disconnect(); sizeConn = nil end
                    end
                end)

                -- Proxy all tabAPI methods into the folder's Objects frame
                for methodName, method in pairs(tabAPI) do
                    folderAPI[methodName] = function(...)
                        local results = { method(...) }
                        local element = results[#results]
                        element.Parent = folderList
                        return table.unpack(results)
                    end
                end

                return folderAPI, folder
            end

            return tabAPI, contentFrame
        end
    end

    -- Bump ZIndex on all window descendants for proper layering
    for _, descendant in ipairs(win:GetDescendants()) do
        if safeGet(descendant, "ZIndex") then
            descendant.ZIndex = descendant.ZIndex + windowCount * 10
        end
    end

    return windowAPI, win
end

-- Cleanup connections when the script is removed
script.AncestryChanged:Connect(function()
    if not script.Parent then
        cleanup()
    end
end)

return Library
