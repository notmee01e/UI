            --// ── tabAPI:AddSwitch ──────────────────────────
            function tabAPI:AddSwitch(label, callback)
                local switchAPI = {}
                label    = tostring(label or "New Switch")
                callback = typeof(callback) == "function" and callback or function() end

                local sw     = Prefabs:FindFirstChild("Switch"):Clone()
                local target = contentFrame:FindFirstChild("TabScroller") or contentFrame
                sw.Parent    = target
                sw:FindFirstChild("Title").Text = label
                sw:FindFirstChild("Title").ZIndex = sw:FindFirstChild("Title").ZIndex + windowCount * 10
                sw.ZIndex    = sw.ZIndex + windowCount * 10

