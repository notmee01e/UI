--// ─────────────────────────────────────────────────────────
--//  LAYOUT HELPER: position all windows to their absolute spots
--// ─────────────────────────────────────────────────────────
local function snapWindowsToAbsolute()
    -- Temporarily add a layout, record positions, then remove it
    local layout = Prefabs:FindFirstChild("UIListLayout"):Clone()
    layout.Parent = WindowsContainer

    local positions = {}
    for _, child in ipairs(WindowsContainer:GetChildren()) do
        if not child:IsA("UIListLayout") then
            positions[child] = child.AbsolutePosition
        end
    end

    layout:Destroy()

    for child, pos in pairs(positions) do
        child.Position = UDim2.new(0, pos.X, 0, pos.Y)
    end
end

