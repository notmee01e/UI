            local layout = contentFrame:FindFirstChildOfClass("UIListLayout")
            if layout then layout.Parent = scroller end

            -- Auto-resize scroller canvas
            local function updateCanvas()
                scroller.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
            end
            layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)
            updateCanvas()

            task.defer(refreshTabLayout)

            -- Wire up the tab button
            tabBtn.MouseButton1Click:Connect(function() selectTab(tabBtn, contentFrame) end)
            tabBtn.MouseEnter:Connect(function()
                if tabBtn ~= activeBtn then tabBtn.TextColor3 = Color3.fromRGB(230, 230, 230) end
            end)
            tabBtn.MouseLeave:Connect(function()
                if tabBtn ~= activeBtn then tabBtn.TextColor3 = Color3.fromRGB(200, 200, 200) end
            end)

            -- Auto-select if it's the first tab
            if #tabBtnsF:GetChildren() == 2 then
                selectTab(tabBtn, contentFrame)
            end

            tabBtn.AncestryChanged:Connect(function()
                if not tabBtn.Parent then
                    if activeBtn == tabBtn then
                        activeBtn = nil
                        if particleConn then particleConn:Disconnect(); particleConn = nil end
                    end
                end
