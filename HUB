    --// ── Tab management ───────────────────────────────────
    do
        local tabsFrame   = win:FindFirstChild("Tabs")
        local tabSelBar   = win:FindFirstChild("TabSelection")
        local tabScrollF  = tabSelBar:FindFirstChild("TabScrolling")
        local tabBtnsF    = tabScrollF:FindFirstChild("TabButtons")
        local activeBtn   = nil    -- currently selected tab button
        local particleConn = nil  -- particle emitter connection

        -- Recalculate tab button container width
        local function refreshTabLayout()
            local totalW  = 0
            local padding = tabBtnsF:FindFirstChildOfClass("UIListLayout").Padding.Offset or 0
            for _, child in ipairs(tabBtnsF:GetChildren()) do
                if child:IsA("TextButton") then
                    totalW = totalW + child.AbsoluteSize.X + padding
                end
            end
            tabBtnsF.Size              = UDim2.new(0, totalW, 1, 0)
            if tabScrollF then
                tabScrollF.CanvasSize  = UDim2.new(0, totalW, 0, 0)
            end
        end

        --- ⚡ BLUE THUNDER HIGHLIGHT on the active tab button
        --- Draws mini electric arcs inside/around the selected tab
        local function emitTabParticles(btn)
            if btn ~= activeBtn then return end
            local size = btn.AbsoluteSize
            if size.X < 5 or size.Y < 5 then return end

            -- === ELECTRIC ARC SEGMENTS ===
            task.spawn(function()
                -- Pick two random points on the button edges
                local x1 = math.random(2, math.max(3, size.X - 2))
                local y1 = math.random(1, math.max(2, size.Y - 1))
                local x2 = x1 + math.random(-12, 12)
                local y2 = y1 + math.random(-8,  8)

                local arcColors = {
                    Color3.fromRGB(80,  180, 255),  -- electric blue
                    Color3.fromRGB(120, 210, 255),  -- light cyan-blue
                    Color3.fromRGB(200, 240, 255),  -- near-white blue
                    Color3.fromRGB(60,  140, 255),  -- pure blue
                }
                local col = arcColors[math.random(#arcColors)]

                -- Draw 2–4 jagged segments forming a mini arc
                local segs = math.random(2, 4)
                local pts  = { Vector2.new(x1, y1) }
                for s = 1, segs - 1 do
                    local t  = s / segs
                    local mx = x1 + (x2 - x1) * t + math.random(-5, 5)
                    local my = y1 + (y2 - y1) * t + math.random(-4, 4)
                    table.insert(pts, Vector2.new(mx, my))
                end
                table.insert(pts, Vector2.new(x2, y2))

                local segFrames = {}
                for s = 1, #pts - 1 do
                    local p1 = pts[s];  local p2 = pts[s+1]
                    local dx = p2.X - p1.X;  local dy = p2.Y - p1.Y
                    local ln = math.sqrt(dx*dx + dy*dy)
                    if ln < 0.5 then continue end
                    local ang = math.deg(math.atan2(dy, dx))

                    local seg              = Instance.new("Frame")
                    seg.Size               = UDim2.new(0, ln, 0, math.random(1, 2))
                    seg.Position           = UDim2.new(0, p1.X, 0, p1.Y)
                    seg.Rotation           = ang
                    seg.BackgroundColor3   = col
                    seg.BackgroundTransparency = 0.05
                    seg.BorderSizePixel    = 0
                    seg.ZIndex             = btn.ZIndex + 20
                    seg.AnchorPoint        = Vector2.new(0, 0.5)
                    seg.Parent             = btn
                    table.insert(segFrames, seg)

                    -- Glow halo (wider, faded)
                    local glow             = Instance.new("Frame")
                    glow.Size              = UDim2.new(0, ln, 0, math.random(3, 6))
                    glow.Position          = seg.Position
                    glow.Rotation          = ang
                    glow.BackgroundColor3  = col
                    glow.BackgroundTransparency = 0.6
                    glow.BorderSizePixel   = 0
                    glow.ZIndex            = btn.ZIndex + 19
                    glow.AnchorPoint       = Vector2.new(0, 0.5)
                    glow.Parent            = btn
                    table.insert(segFrames, glow)
                end

                -- Fade out
                task.delay(0.07, function()
                    for _, f in ipairs(segFrames) do
                        if f and f.Parent then
                            TweenService:Create(f,
                                TweenInfo.new(0.12, Enum.EasingStyle.Linear),
                                { BackgroundTransparency = 1 }):Play()
                        end
                    end
                    task.delay(0.13, function()
                        for _, f in ipairs(segFrames) do
                            if f and f.Parent then f:Destroy() end
                        end
                    end)
                end)
            end)

            -- === BLUE SPARK DOT ===
            task.spawn(function()
                local sparkColors = {
                    Color3.fromRGB(80,  180, 255),
                    Color3.fromRGB(180, 230, 255),
                    Color3.fromRGB(60,  140, 255),
                }
                local sp             = Instance.new("Frame")
                sp.Size              = UDim2.new(0, math.random(2, 4), 0, math.random(2, 4))
                sp.AnchorPoint       = Vector2.new(0.5, 0.5)
                sp.BackgroundColor3  = sparkColors[math.random(#sparkColors)]
                sp.BackgroundTransparency = 0.1
                sp.BorderSizePixel   = 0
                sp.ZIndex            = btn.ZIndex + 22
                sp.Position          = UDim2.new(
                    math.random(5, math.max(6, size.X - 5)) / math.max(1, size.X), 0,
                    math.random(1, math.max(2, size.Y - 1)) / math.max(1, size.Y), 0
                )
                sp.Parent = btn
                Instance.new("UICorner", sp).CornerRadius = UDim.new(1, 0)

                -- Shoot outward and fade
                local ex = sp.Position.X.Scale + (math.random(-15, 15) / math.max(1, size.X))
                local ey = sp.Position.Y.Scale + (math.random(-10, 10) / math.max(1, size.Y))
                TweenService:Create(sp,
                    TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
                    { Position = UDim2.new(ex, 0, ey, 0), BackgroundTransparency = 1 }):Play()

                task.delay(0.32, function()
                    if sp and sp.Parent then sp:Destroy() end
                end)
            end)
        end

        local function startParticles()
            if particleConn then particleConn:Disconnect() end
            particleConn = RunService.Heartbeat:Connect(function()
                if activeBtn and activeBtn.Parent then
                    emitTabParticles(activeBtn)
                    task.wait(0.2)
                end
            end)
        end

        --- Select a tab (show its content, deselect others)
        local function selectTab(tabBtn, contentFrame)
            if isMinimized then return end

            -- Deselect previous
            if activeBtn and activeBtn ~= tabBtn then
                local outline = activeBtn:FindFirstChild("TabOutline")
                if outline then outline.Visible = false end
                -- Remove blue thunder stroke from previously active tab
                local prevStroke = activeBtn:FindFirstChild("ThunderStroke")
                if prevStroke then prevStroke:Destroy() end
                activeBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
            end

            -- Hide all tab content frames
            for _, child in ipairs(tabsFrame:GetChildren()) do
                if child:IsA("Frame") then child.Visible = false end
            end

            activeBtn = tabBtn

            local outline = tabBtn:FindFirstChild("TabOutline")
            if outline then
                outline.Visible     = true
                outline.BorderColor3 = options.main_color
            end

            -- ⚡ Blue thunder highlight stroke on active tab
            local oldThunderStroke = tabBtn:FindFirstChild("ThunderStroke")
            if oldThunderStroke then oldThunderStroke:Destroy() end

            local thunderStroke        = Instance.new("UIStroke")
            thunderStroke.Name         = "ThunderStroke"
            thunderStroke.Color        = Color3.fromRGB(80, 180, 255)   -- electric blue
            thunderStroke.Thickness    = 1.5
            thunderStroke.Transparency = 0.0
            thunderStroke.Parent       = tabBtn

            -- Pulse between electric blue and cyan-white
            task.spawn(function()
                local blueShades = {
                    Color3.fromRGB(80,  180, 255),
                    Color3.fromRGB(180, 230, 255),
                    Color3.fromRGB(60,  120, 255),
                    Color3.fromRGB(140, 210, 255),
                }
                local bi = 1
                while thunderStroke and thunderStroke.Parent and activeBtn == tabBtn do
                    bi = (bi % #blueShades) + 1
                    TweenService:Create(thunderStroke,
                        TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                        { Color = blueShades[bi], Transparency = 0.0 }):Play()
                    task.wait(0.4)
                    TweenService:Create(thunderStroke,
                        TweenInfo.new(0.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                        { Color = Color3.fromRGB(40, 100, 220), Transparency = 0.4 }):Play()
                    task.wait(0.4)
                end
                if thunderStroke and thunderStroke.Parent then thunderStroke:Destroy() end
            end)

            -- Remove blue stroke from previously active tab
            if activeBtn and activeBtn ~= tabBtn then
                local prevStroke = activeBtn:FindFirstChild("ThunderStroke")
                if prevStroke then prevStroke:Destroy() end
            end

            tabBtn.TextColor3  = Color3.new(1, 1, 1)
            contentFrame.Visible = true
            startParticles()
        end

        --// ── windowAPI:AddTab ──────────────────────────────
