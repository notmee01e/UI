local bindingActive = false   -- true while waiting for a keybind input
local connections   = {}      -- all event connections (for cleanup)
local windowCount   = 0       -- increments per window (used for ZIndex stacking)
local dropdownOpen  = false   -- true while a dropdown is expanded

