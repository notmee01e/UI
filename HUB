--// ─────────────────────────────────────────────────────────
--//  Library:AddWindow  –  creates a draggable, resizable window
--// ─────────────────────────────────────────────────────────
function Library:AddWindow(title, options)
    windowCount = windowCount + 1
    local isMinimized = false

    title   = tostring(title or "New Window")
    options = typeof(options) == "table" and options or Config

    -- Defaults
    options.tween_time             = options.tween_time or 0.1
    options.title_bar              = options.title_bar  or { Color3.fromRGB(100, 20, 200) }
    if typeof(options.title_bar) == "Color3" then
        options.title_bar = { options.title_bar }
    end
    options.title_bar_transparency = options.title_bar_transparency or 0
    options.background             = options.background or { Color3.fromRGB(15, 6, 30) }
    if typeof(options.background) == "Color3" then
        options.background = { options.background }
    end
    options.background_transparency = options.background_transparency or 0.1
    if not options.main_color then
        options.main_color = options.title_bar[1]
    end

    -- Clone the window prefab
    local win = Prefabs:FindFirstChild("Window"):Clone()
    win.Parent = WindowsContainer
    win:FindFirstChild("Title").Text = title
    win.Size   = UDim2.new(0, options.min_size.X, 0, options.min_size.Y)
    win.ZIndex = win.ZIndex + windowCount * 10

    --// ── Style the title bar ──────────────────────────────
    do
        local bar         = win:FindFirstChild("Bar")
        local barTitle    = bar:FindFirstChild("Title")
        local barToggle   = bar:FindFirstChild("Toggle")
        local barBase     = bar:FindFirstChild("Base")
        local barTop      = bar:FindFirstChild("Top")
        local tabSel      = win:FindFirstChild("TabSelection")
        local tabSelFrame = tabSel:FindFirstChild("Frame")

        local barHeight = 24
        local barPad    = (barHeight - 18) / 2

        bar.Size     = UDim2.new(1, 0, 0, barHeight)
        bar.Position = UDim2.new(0, 0, 0, 0)

        -- Remove old base/top pieces (replaced by UICorner)
        if barBase then barBase:Destroy() end
        if barTop  then barTop:Destroy()  end

        local corner        = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 5)
        corner.Parent       = bar

        if barToggle then
            barToggle.Position = UDim2.new(0, 5, 0, barPad)
        end

        if barTitle then
            barTitle.Position       = UDim2.new(0, 25, 0, barPad)
            barTitle.Size           = UDim2.new(1, -(25 + 5), 1, -barPad * 2)
            barTitle.TextXAlignment = Enum.TextXAlignment.Center
        end

        bar.BackgroundTransparency = options.title_bar_transparency
        applyColor(bar, options.title_bar, 0)

        if tabSel then
            tabSel.Size     = UDim2.new(1, -30, 0, 22)
            tabSel.Position = UDim2.new(0, 15, 0, 28)

            local tabCorner        = Instance.new("UICorner")
            tabCorner.CornerRadius = UDim.new(0, 6)
            tabCorner.Parent       = tabSel

            tabSel.ImageTransparency = 0.4
            applyColor(tabSel, options.title_bar, 45)

            local tabScrolling = tabSel:FindFirstChild("TabScrolling")
            if tabScrolling then
                local tabBtns = tabScrolling:FindFirstChild("TabButtons")
                if tabBtns then
                    local layout = tabBtns:FindFirstChild("UIListLayout")
                    if layout then
                        layout.VerticalAlignment = Enum.VerticalAlignment.Center
                        layout.Padding           = UDim.new(0, 12)
                    end
                end
            end

            if tabSelFrame then tabSelFrame:Destroy() end
        end

        win.ImageTransparency = options.background_transparency
        applyColor(win, options.background, 45)

        --// ── 🌌 ANIMATED BACKGROUND LAYER ────────────────
        -- A semi-transparent canvas that sits behind all content
        -- and shows drifting aurora bands + floating glow orbs
        local bgCanvas              = Instance.new("Frame")
        bgCanvas.Name               = "BgCanvas"
        bgCanvas.Size               = UDim2.new(1, 0, 1, 0)
        bgCanvas.BackgroundColor3   = Color3.fromRGB(10, 4, 22)
        bgCanvas.BackgroundTransparency = 0.15
        bgCanvas.BorderSizePixel    = 0
        bgCanvas.ZIndex             = 1
        bgCanvas.ClipsDescendants   = true
        bgCanvas.Parent             = win

        -- Aurora sweep bands (horizontal gradient bars that drift slowly)
        local auroraColors = {
            Color3.fromRGB(60, 10, 130),    -- deep purple band
            Color3.fromRGB(30, 0, 100),     -- near-black purple
            Color3.fromRGB(80, 20, 160),    -- mid violet band
            Color3.fromRGB(20, 50, 140),    -- blue-purple band
        }
        for i = 1, 4 do
            local band              = Instance.new("Frame")
            band.Name               = "AuroraBand"..i
            band.Size               = UDim2.new(1.4, 0, 0, math.random(30, 60))
            band.Position           = UDim2.new(-0.2, 0, (i - 1) * 0.26, 0)
            band.BackgroundColor3   = auroraColors[i]
            band.BackgroundTransparency = 0.72
            band.BorderSizePixel    = 0
            band.ZIndex             = 1
            band.Rotation           = math.random(-8, 8)
            band.Parent             = bgCanvas

            -- Slow drift animation — each band drifts at different speed/direction
            local function driftBand()
                local speed   = math.random(40, 90) / 10   -- 4–9 seconds
                local targetY = (i - 1) * 0.26 + (math.random() > 0.5 and 0.08 or -0.08)
                TweenService:Create(band,
                    TweenInfo.new(speed, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                    {
                        Position = UDim2.new(-0.2, 0, targetY, 0),
                        Rotation = math.random(-10, 10),
                        BackgroundTransparency = math.random(65, 82) / 100,
                    }
                ):Play()
                task.delay(speed, driftBand)
            end
            task.delay(i * 0.3, driftBand)
        end

        -- Floating glow orbs — soft circles that wander around the bg
        local orbColors = {
            Color3.fromRGB(100, 20, 200),
            Color3.fromRGB(0,   80, 220),   -- blue orb
            Color3.fromRGB(130, 40, 255),
            Color3.fromRGB(20, 100, 200),   -- cyan-blue orb
        }
        task.spawn(function()
            local orbAlive = true
            bgCanvas.AncestryChanged:Connect(function()
                if not bgCanvas.Parent then orbAlive = false end
            end)

            while orbAlive do
                task.wait(math.random(8, 18) / 10)
                if not orbAlive then break end

                local orb               = Instance.new("Frame")
                local sz                = math.random(18, 45)
                orb.Size                = UDim2.new(0, sz, 0, sz)
                orb.Position            = UDim2.new(math.random(5,90)/100, 0, math.random(10,85)/100, 0)
                orb.BackgroundColor3    = orbColors[math.random(#orbColors)]
                orb.BackgroundTransparency = 0.55
                orb.BorderSizePixel     = 0
                orb.ZIndex              = 1
                orb.AnchorPoint         = Vector2.new(0.5, 0.5)
                orb.Parent              = bgCanvas
                Instance.new("UICorner", orb).CornerRadius = UDim.new(1, 0)

                -- Add a UIGradient radial-ish fade by using a gradient
                local grad          = Instance.new("UIGradient")
                grad.Transparency   = NumberSequence.new({
                    NumberSequenceKeypoint.new(0,   0.3),
                    NumberSequenceKeypoint.new(0.5, 0.55),
                    NumberSequenceKeypoint.new(1,   1),
                })
                grad.Parent = orb

                -- Drift to random nearby position then fade out
                local driftX = orb.Position.X.Scale + (math.random(-20,20)/100)
                local driftY = orb.Position.Y.Scale + (math.random(-15,15)/100)
                local life   = math.random(30, 60) / 10

                TweenService:Create(orb,
                    TweenInfo.new(life, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                    {
                        Position = UDim2.new(
                            math.clamp(driftX, 0.03, 0.95), 0,
                            math.clamp(driftY, 0.05, 0.90), 0
                        ),
                        BackgroundTransparency = 0.85,
                    }
                ):Play()

                task.delay(life, function()
                    if orb and orb.Parent then orb:Destroy() end
                end)
            end
        end)

        -- Scanline shimmer — a thin bright line that sweeps down periodically
        task.spawn(function()
            while bgCanvas and bgCanvas.Parent do
                task.wait(math.random(35, 65) / 10)
                if not (bgCanvas and bgCanvas.Parent) then break end

                local line              = Instance.new("Frame")
                line.Size               = UDim2.new(1, 0, 0, 2)
                line.Position           = UDim2.new(0, 0, 0, 0)
                line.BackgroundColor3   = Color3.fromRGB(150, 80, 255)
                line.BackgroundTransparency = 0.3
                line.BorderSizePixel    = 0
                line.ZIndex             = 2
                line.Parent             = bgCanvas

                TweenService:Create(line,
                    TweenInfo.new(1.4, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
                    { Position = UDim2.new(0, 0, 1, 0), BackgroundTransparency = 0.85 }
                ):Play()
                task.delay(1.5, function()
                    if line and line.Parent then line:Destroy() end
                end)
            end
        end)

        --// ── ⚡ VIOLET GLOW BORDER (animated) ─────────────
        local glowStroke        = Instance.new("UIStroke")
        glowStroke.Color        = Color3.fromRGB(180, 90, 255)   -- vivid purple glow
        glowStroke.Thickness    = 2.5
        glowStroke.Transparency = 0.2
        glowStroke.Parent       = win

        -- 💜 Pulse the border glow between purple shades
        task.spawn(function()
            local pulseColors = {
                Color3.fromRGB(200, 100, 255),  -- bright lavender
                Color3.fromRGB(130,  50, 230),  -- deep violet
                Color3.fromRGB(220, 150, 255),  -- soft pink-purple
                Color3.fromRGB(100,  20, 200),  -- dark accent
            }
            local idx = 1
            while glowStroke and glowStroke.Parent do
                idx = (idx % #pulseColors) + 1
                TweenService:Create(glowStroke,
                    TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                    { Color = pulseColors[idx], Transparency = 0.0 }):Play()
                task.wait(1.2)
                TweenService:Create(glowStroke,
                    TweenInfo.new(1.2, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
                    { Color = Color3.fromRGB(75, 10, 175), Transparency = 0.5 }):Play()
