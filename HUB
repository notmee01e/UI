--- Track a connection so it can be cleaned up later
local function trackConnection(conn)
    table.insert(connections, conn)
    return conn
end

--- Disconnect and clear all tracked connections
local function cleanup()
    for _, conn in ipairs(connections) do
        if conn.Connected then conn:Disconnect() end
    end
    connections = {}
end

--- Tween an object's properties. If duration is 0, apply instantly.
local function tween(obj, props, duration)
    duration = duration or 0.1
    if duration == 0 then
        for k, v in pairs(props) do obj[k] = v end
        return
    end
    local info   = TweenInfo.new(duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local t      = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

--- Apply a solid color or gradient to a frame/image
local function applyColor(obj, colors, rotation)
    local existing = obj:FindFirstChild("UIGradient")
    if existing then existing:Destroy() end

    if typeof(colors) == "Color3" then colors = {colors} end
    if not colors or #colors == 0 then return end

    if #colors == 1 then
        -- Single solid color
        if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
            obj.ImageColor3 = colors[1]
        else
            obj.BackgroundColor3 = colors[1]
        end
        return
    end

    -- Multiple colors → UIGradient
    local grad     = Instance.new("UIGradient")
    grad.Parent    = obj
    grad.Rotation  = rotation or 0

    local keypoints = {}
    if #colors == 2 then
        keypoints = {
            ColorSequenceKeypoint.new(0,   colors[1]),
            ColorSequenceKeypoint.new(1,   colors[2]),
        }
    elseif #colors >= 3 then
        keypoints = {
            ColorSequenceKeypoint.new(0,   colors[1]),
            ColorSequenceKeypoint.new(0.5, colors[2]),
            ColorSequenceKeypoint.new(1,   colors[3]),
        }
    end

    grad.Color = ColorSequence.new(keypoints)

    -- When using gradient, base color must be white
    if obj:IsA("ImageLabel") or obj:IsA("ImageButton") then
        obj.ImageColor3 = Color3.new(1, 1, 1)
    else
        obj.BackgroundColor3 = Color3.new(1, 1, 1)
    end
end

--- Convert RGB (0-255) to HSV (0-1 each)
local function rgbToHsv(r, g, b)
    r, g, b = r / 255, g / 255, b / 255
    local max, min  = math.max(r, g, b), math.min(r, g, b)
    local h, s, v   = 0, 0, max
    local delta     = max - min

    s = max == 0 and 0 or delta / max

    if max ~= min then
        if     max == r then h = (g - b) / delta + (g < b and 6 or 0)
        elseif max == g then h = (b - r) / delta + 2
        elseif max == b then h = (r - g) / delta + 4
        end
        h = h / 6
    end

    return h, s, v
end

--- Safely index a property on an object (pcall wrapper)
local function safeGet(obj, key)
    local ok, val = pcall(function() return obj[tostring(key)] end)
    return ok and val
end

--- Get the pixel width of a TextLabel's text content
local function getTextWidth(label)
    return label.TextBounds.X + 15
end

--- Get the current mouse position (adjusted for top bar inset)
local function getMousePos()
    local pos = UserInputService:GetMouseLocation()
    return Vector2.new(pos.X + 1, pos.Y - 35)
end

--- Play a ripple/click animation on a frame at the given screen position
local function playRipple(frame, screenX, screenY)
    task.spawn(function()
        frame.ClipsDescendants = true

        local circle = Prefabs:FindFirstChild("Circle"):Clone()
        circle.Parent = frame
        circle.ZIndex = 1000

        local relX = screenX - circle.AbsolutePosition.X
        local relY = screenY - circle.AbsolutePosition.Y
        circle.Position = UDim2.new(0, relX, 0, relY)

        local targetSize = math.max(frame.AbsoluteSize.X, frame.AbsoluteSize.Y) * 1.5
        circle:TweenSizeAndPosition(
            UDim2.new(0, targetSize, 0, targetSize),
            UDim2.new(0.5, -targetSize / 2, 0.5, -targetSize / 2),
            Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.5, false
        )
        tween(circle, { ImageTransparency = 1 }, 0.5)

        task.wait(0.5)
        if circle and circle.Parent then circle:Destroy() end
    end)
end

